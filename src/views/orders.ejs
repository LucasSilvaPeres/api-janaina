<%- include('partials/header', { currentPage }) %>

<div class="mb-5 pb-4 border-b border-[#d0d7de]">
  <h1 class="text-xl font-semibold text-[#1f2328]">Pedidos</h1>
</div>

<% if (error === 'vehicle_unavailable') { %>
  <div class="bg-[#fff0ee] border border-[#ffc1ba] text-[#cf222e] rounded-md px-4 py-3 text-sm mb-5">
    Este veículo já foi vendido e não pode ser incluído em novo pedido.
  </div>
<% } %>

<div class="bg-[#f6f8fa] border border-[#d0d7de] rounded-md p-4 mb-5">
  <h2 class="text-sm font-semibold text-[#1f2328] mb-3">Criar novo pedido</h2>
  <form method="POST" action="/orders" class="flex gap-3 flex-wrap items-end">
    <div>
      <label class="block text-xs font-medium text-[#1f2328] mb-1">Cliente</label>
      <select name="clientId"
              class="border border-[#d0d7de] rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#0969da] bg-white">
        <% clients.forEach(c => { %>
          <option value="<%= c.id %>"><%= c.name %></option>
        <% }) %>
      </select>
    </div>
    <div>
      <label class="block text-xs font-medium text-[#1f2328] mb-1">Veículo</label>
      <select name="vehicleId"
              class="border border-[#d0d7de] rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#0969da] bg-white">
        <% vehicles.forEach(v => { %>
          <option value="<%= v.id %>"><%= v.brand %> <%= v.model %> (<%= v.year %>)</option>
        <% }) %>
      </select>
    </div>
    <button type="submit"
            class="bg-[#1f883d] hover:bg-[#1a7f37] text-white border border-[#1a7f37] rounded-md px-3 py-1.5 text-sm font-medium">
      Criar Pedido
    </button>
  </form>
</div>

<div class="border border-[#d0d7de] rounded-md overflow-hidden">
  <% if (orders.length === 0) { %>
    <div class="px-4 py-8 text-center text-sm text-[#636c76]">Nenhum pedido registrado.</div>
  <% } else { %>
    <% orders.forEach(o => { %>
      <div class="flex items-center gap-3 px-4 py-3 border-b border-[#d0d7de] last:border-b-0">
        <span class="bg-[#dafbe1] text-[#1a7f37] border border-[#aceebb] px-2 py-0.5 rounded-full text-xs font-medium">#<%= o.id %></span>
        <span class="text-sm text-[#1f2328]"><%= o.clientName %></span>
        <span class="text-xs text-[#636c76]">→</span>
        <span class="text-sm text-[#1f2328]"><%= o.vehicleName %></span>
      </div>
    <% }) %>
  <% } %>
</div>

<%- include('partials/footer') %>
